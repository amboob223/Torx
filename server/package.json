    "start": "node index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "groq-sdk": "^1.2.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.42.0",
    "pg": "^8.12.0",
    "socket.io": "^4.8.3",
    "stripe": "^16.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "concurrently": "^9.0.0"
  }
}